{
  "name": "fire-spread-monorepo",
  "private": true,
  "workspaces": [
    "app/backend/src",
    "app/frontend/src",
    "app/pwa"
  ],
  "scripts": {
    "dev": "yarn --cwd app/frontend/src dev",
    "build": "yarn --cwd app/frontend/src build",
    "lint": "yarn --cwd app/frontend/src lint",
    "test:e2e": "yarn --cwd app/frontend/src test:e2e",
    "test:e2e:backend": "pytest -q app/backend/src/testing_config/e2e",
    "pwa:start": "yarn --cwd app/pwa start"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.5.0",
    "daisyui": "^5.5.19",
    "postcss": "^8.5.14"
  },
  "dependencies": {
    "lucide-react": "^1.16.0"
  },
  "resolutions": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}